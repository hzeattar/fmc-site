{
	# FrankenPHP configuration for FMC site
	admin off
	auto_https off
}

:{$PORT:8080} {
	# Route PHP files through FrankenPHP
	@php {
		path *.php
	}

	# Use FrankenPHP's built-in PHP handler
	route @php {
		php {
			root /app
		}
	}

	# Serve static files
	file_server {
		root /app
	}

	# Try files pattern
	try_files {path} {path}/ /index.php
}
